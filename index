<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="theme-color" content="#0a0f1e" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <title>PharmaPOS</title>

  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- html5-qrcode -->
  <script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>

  <!-- Google Fonts: Syne (display) + Noto Sans Arabic (body/bilingual) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Noto+Sans+Arabic:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand:  { DEFAULT: '#00d4aa', dark: '#00a885', light: '#7fffd4' },
            surface: { 1: '#0a0f1e', 2: '#111827', 3: '#1a2235', 4: '#232f46' },
            ink:    { DEFAULT: '#e8f0fe', muted: '#8899bb', faint: '#2d3f61' },
          },
          fontFamily: {
            display: ['Syne', 'sans-serif'],
            body:    ['Noto Sans Arabic', 'Syne', 'sans-serif'],
          },
        }
      }
    };
  </script>

  <style>
    :root {
      --safe-top:    env(safe-area-inset-top,    0px);
      --safe-bottom: env(safe-area-inset-bottom, 0px);
    }

    * { -webkit-tap-highlight-color: transparent; box-sizing: border-box; }

    html, body {
      height: 100%; width: 100%; overflow: hidden;
      background: #0a0f1e;
      font-family: 'Noto Sans Arabic', 'Syne', sans-serif;
      color: #e8f0fe;
    }

    /* ── App Shell ── */
    #app {
      display: flex; flex-direction: column;
      height: 100dvh; width: 100%;
      padding-top: var(--safe-top);
      padding-bottom: var(--safe-bottom);
      position: relative; overflow: hidden;
    }

    /* ── Topbar ── */
    #topbar {
      flex-shrink: 0;
      display: flex; align-items: center; justify-content: space-between;
      padding: 12px 20px 10px;
      background: rgba(10,15,30,0.92);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255,255,255,0.06);
      z-index: 50;
    }

    .logo { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.25rem;
            background: linear-gradient(135deg, #00d4aa 30%, #7fffd4);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent; }

    /* ── Lang Toggle ── */
    .lang-pill {
      display: flex; background: #1a2235; border-radius: 20px; padding: 3px; gap: 2px;
    }
    .lang-btn {
      font-family: 'Syne', sans-serif; font-size: 0.7rem; font-weight: 700;
      padding: 4px 12px; border-radius: 16px; border: none; cursor: pointer;
      transition: all .25s ease; color: #8899bb; background: transparent;
      letter-spacing: .05em;
    }
    .lang-btn.active { background: #00d4aa; color: #0a0f1e; }

    /* ── Screens ── */
    #screen-wrap {
      flex: 1; overflow: hidden; position: relative;
    }
    .screen {
      position: absolute; inset: 0;
      display: flex; flex-direction: column; overflow: hidden;
      opacity: 0; pointer-events: none;
      transition: opacity .2s ease;
    }
    .screen.active { opacity: 1; pointer-events: all; }

    /* ── POS Layout ── */
    #pos-screen {
      background: #0a0f1e;
    }

    /* Scanner area */
    #scanner-section {
      flex-shrink: 0;
      position: relative;
      padding: 12px 16px 0;
    }
    #scanner-card {
      background: #111827;
      border-radius: 20px;
      overflow: hidden;
      border: 1px solid rgba(0,212,170,0.15);
      position: relative;
    }

    /* html5-qrcode container */
    #reader {
      width: 100%;
      min-height: 220px;
      background: #0a0f1e;
      position: relative;
    }
    /* Override html5-qrcode default styles — iOS Safari critical fixes */
    #reader video {
      object-fit: cover !important;
      border-radius: 0 !important;
      /* Prevent iOS Safari from hijacking video into native fullscreen player */
      width: 100% !important;
      height: 100% !important;
      max-height: 240px !important;
      display: block !important;
      /* These mirror the attributes we set via JS observer */
      -webkit-playsinline: true;
    }
    /* Hide the library's own file-upload / image-scan UI — camera only */
    #reader img { display: none !important; }
    #reader__scan_region { border-radius: 0 !important; }
    /* Hide "Scan type" toggle that can expose file picker on mobile */
    #reader__scan_type_change_anchor { display: none !important; }
    #reader__dashboard_section_swaplink { display: none !important; }
    #reader__status_span {
      background: rgba(0,212,170,0.15) !important;
      color: #00d4aa !important;
      font-family: 'Syne', sans-serif !important;
      font-size: 0.75rem !important;
      border-radius: 6px !important;
    }
    #reader__dashboard { background: #111827 !important; padding: 8px 12px !important; }
    #reader__dashboard_section_csr button,
    #reader__dashboard_section_fsr button {
      background: #00d4aa !important;
      color: #0a0f1e !important;
      border: none !important;
      border-radius: 10px !important;
      font-family: 'Syne', sans-serif !important;
      font-weight: 700 !important;
      padding: 8px 20px !important;
      font-size: 0.8rem !important;
      cursor: pointer !important;
    }

    /* Scan overlay corners */
    .scan-overlay {
      position: absolute; inset: 0;
      pointer-events: none; z-index: 10;
    }
    .corner {
      position: absolute; width: 22px; height: 22px;
      border-color: #00d4aa; border-style: solid; border-width: 0;
    }
    .corner.tl { top: 12px; left: 12px; border-top-width: 3px; border-left-width: 3px; border-top-left-radius: 6px; }
    .corner.tr { top: 12px; right: 12px; border-top-width: 3px; border-right-width: 3px; border-top-right-radius: 6px; }
    .corner.bl { bottom: 12px; left: 12px; border-bottom-width: 3px; border-left-width: 3px; border-bottom-left-radius: 6px; }
    .corner.br { bottom: 12px; right: 12px; border-bottom-width: 3px; border-right-width: 3px; border-bottom-right-radius: 6px; }

    /* Scan pulse line */
    @keyframes scan-line {
      0%   { top: 15%; opacity: 1; }
      100% { top: 85%; opacity: 0.4; }
    }
    .scan-line {
      position: absolute; left: 10%; right: 10%; height: 2px;
      background: linear-gradient(90deg, transparent, #00d4aa, transparent);
      border-radius: 2px;
      animation: scan-line 2s ease-in-out infinite alternate;
    }
    #scanner-card.idle .scan-line { display: none; }

    /* Tap-to-scan placeholder */
    #tap-placeholder {
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      min-height: 220px; gap: 10px; padding: 20px;
      cursor: pointer;
    }
    #tap-placeholder.hidden { display: none; }

    .scan-icon-ring {
      width: 72px; height: 72px; border-radius: 50%;
      background: rgba(0,212,170,0.08);
      border: 2px dashed rgba(0,212,170,0.4);
      display: flex; align-items: center; justify-content: center;
      animation: pulse-ring 2.5s ease infinite;
    }
    @keyframes pulse-ring {
      0%,100% { box-shadow: 0 0 0 0 rgba(0,212,170,0.25); }
      50%      { box-shadow: 0 0 0 12px rgba(0,212,170,0); }
    }

    /* Scanner label bar */
    .scanner-label {
      display: flex; align-items: center; justify-content: space-between;
      padding: 10px 14px 12px;
    }
    .scan-badge {
      font-size: 0.65rem; font-weight: 700; letter-spacing: .08em;
      color: #00d4aa; background: rgba(0,212,170,0.12);
      padding: 3px 10px; border-radius: 12px; text-transform: uppercase;
    }
    .scan-count-badge {
      font-size: 0.65rem; font-weight: 600; color: #8899bb;
    }

    /* ── Cart Section ── */
    #cart-section {
      flex: 1; overflow-y: auto; padding: 6px 16px 0;
      overscroll-behavior: contain;
      -webkit-overflow-scrolling: touch;
    }
    #cart-section::-webkit-scrollbar { display: none; }

    .cart-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 10px 0 8px;
    }
    .cart-title {
      font-family: 'Syne', sans-serif; font-weight: 700; font-size: 0.85rem;
      color: #8899bb; text-transform: uppercase; letter-spacing: .08em;
    }
    .clear-btn {
      font-size: 0.72rem; color: #ff6b6b;
      background: rgba(255,107,107,0.1); border: none;
      padding: 3px 10px; border-radius: 10px; cursor: pointer;
      font-family: 'Syne', sans-serif; font-weight: 600;
    }

    /* Cart Item Card */
    .cart-item {
      background: #111827;
      border-radius: 14px;
      padding: 12px 14px;
      margin-bottom: 8px;
      display: flex; align-items: center; gap: 12px;
      border: 1px solid rgba(255,255,255,0.05);
      animation: item-in .3s cubic-bezier(.34,1.56,.64,1);
    }
    @keyframes item-in {
      from { opacity: 0; transform: translateY(12px) scale(0.96); }
      to   { opacity: 1; transform: none; }
    }

    .item-icon {
      width: 40px; height: 40px; border-radius: 10px; flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.1rem;
    }
    .item-info { flex: 1; min-width: 0; }
    .item-name {
      font-weight: 700; font-size: 0.88rem; color: #e8f0fe;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .item-meta { font-size: 0.72rem; color: #8899bb; margin-top: 1px; }

    .item-controls {
      display: flex; align-items: center; gap: 6px; flex-shrink: 0;
    }
    .qty-btn {
      width: 28px; height: 28px; border-radius: 8px; border: none;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.1rem; font-weight: 700; cursor: pointer;
      transition: transform .15s ease, background .15s ease;
    }
    .qty-btn:active { transform: scale(0.88); }
    .qty-minus { background: rgba(255,255,255,0.07); color: #8899bb; }
    .qty-plus  { background: rgba(0,212,170,0.15); color: #00d4aa; }
    .qty-val   {
      font-family: 'Syne', sans-serif; font-weight: 700;
      font-size: 0.9rem; color: #e8f0fe; min-width: 20px; text-align: center;
    }
    .item-price {
      font-family: 'Syne', sans-serif; font-weight: 700;
      font-size: 0.88rem; color: #00d4aa; flex-shrink: 0; text-align: end;
      min-width: 52px;
    }

    /* Empty cart state */
    #empty-cart {
      display: flex; flex-direction: column; align-items: center;
      justify-content: center; padding: 32px 0; gap: 8px; color: #2d3f61;
    }
    #empty-cart svg { width: 40px; height: 40px; opacity: .4; }
    #empty-cart p { font-size: 0.8rem; font-weight: 600; }

    /* ── Checkout Footer ── */
    #checkout-footer {
      flex-shrink: 0;
      padding: 12px 16px 8px;
      background: rgba(10,15,30,0.95);
      backdrop-filter: blur(16px);
      border-top: 1px solid rgba(255,255,255,0.06);
    }
    .totals-row {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 10px;
    }
    .totals-label { font-size: 0.78rem; color: #8899bb; font-weight: 600; }
    .totals-label span { display: block; font-size: 0.65rem; color: #2d3f61; margin-top: 1px; }
    .totals-amount {
      font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.5rem;
      color: #e8f0fe;
    }
    .totals-currency { font-size: 0.75rem; color: #8899bb; font-weight: 600; margin-inline-start: 3px; }

    .checkout-btn {
      width: 100%; padding: 15px;
      background: linear-gradient(135deg, #00d4aa, #00a885);
      color: #0a0f1e; border: none; border-radius: 16px;
      font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1rem;
      letter-spacing: .03em; cursor: pointer;
      box-shadow: 0 4px 24px rgba(0,212,170,0.35);
      transition: transform .15s ease, box-shadow .15s ease, opacity .15s;
      display: flex; align-items: center; justify-content: center; gap: 8px;
    }
    .checkout-btn:active { transform: scale(0.97); box-shadow: 0 2px 12px rgba(0,212,170,0.2); }
    .checkout-btn:disabled { opacity: 0.4; cursor: default; }

    /* ── Bottom Nav ── */
    #bottom-nav {
      flex-shrink: 0;
      display: flex; align-items: stretch;
      background: #0d1526;
      border-top: 1px solid rgba(255,255,255,0.07);
      padding-bottom: calc(var(--safe-bottom) + 2px);
    }
    .nav-item {
      flex: 1; display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      padding: 8px 4px 6px; gap: 3px;
      cursor: pointer; border: none; background: transparent;
      transition: color .2s ease;
      color: #2d3f61; position: relative;
    }
    .nav-item.active { color: #00d4aa; }
    .nav-item svg { width: 22px; height: 22px; flex-shrink: 0; }
    .nav-label { font-size: 0.6rem; font-weight: 700; letter-spacing: .04em; }
    .nav-dot {
      position: absolute; top: 6px; width: 4px; height: 4px;
      background: #00d4aa; border-radius: 2px;
      transition: transform .25s cubic-bezier(.34,1.56,.64,1);
    }
    .nav-item:not(.active) .nav-dot { transform: scale(0); }
    .nav-item.active .nav-dot { transform: scale(1); }

    /* ── Placeholder Screens ── */
    .placeholder-screen {
      flex: 1; display: flex; flex-direction: column;
      align-items: center; justify-content: center; gap: 14px;
      padding: 40px 24px; text-align: center;
    }
    .placeholder-icon {
      width: 72px; height: 72px; border-radius: 20px;
      background: #111827; border: 1px solid rgba(255,255,255,0.07);
      display: flex; align-items: center; justify-content: center; font-size: 1.8rem;
    }
    .placeholder-title {
      font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.2rem;
    }
    .placeholder-sub { font-size: 0.82rem; color: #8899bb; line-height: 1.6; max-width: 260px; }
    .coming-badge {
      font-size: 0.65rem; font-weight: 700; letter-spacing: .1em;
      color: #00d4aa; background: rgba(0,212,170,0.1);
      padding: 5px 14px; border-radius: 12px; text-transform: uppercase;
    }

    /* ── Toast ── */
    #toast {
      position: fixed; top: calc(var(--safe-top) + 66px); left: 50%; z-index: 1000;
      transform: translateX(-50%) translateY(-8px);
      background: #1a2235; border: 1px solid rgba(0,212,170,0.3);
      color: #e8f0fe; border-radius: 14px;
      padding: 10px 20px; font-size: 0.82rem; font-weight: 600;
      display: flex; align-items: center; gap: 8px;
      opacity: 0; transition: opacity .25s, transform .25s;
      pointer-events: none; white-space: nowrap;
      box-shadow: 0 8px 32px rgba(0,0,0,0.5);
    }
    #toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
    #toast.success .toast-dot { background: #00d4aa; }
    #toast.error   .toast-dot { background: #ff6b6b; }
    .toast-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }

    /* ── Checkout Modal ── */
    #checkout-modal {
      position: fixed; inset: 0; z-index: 200;
      background: rgba(0,0,0,0.7); backdrop-filter: blur(8px);
      display: flex; align-items: flex-end;
      opacity: 0; pointer-events: none; transition: opacity .3s ease;
    }
    #checkout-modal.open { opacity: 1; pointer-events: all; }
    .modal-sheet {
      width: 100%; background: #111827;
      border-radius: 24px 24px 0 0;
      padding: 20px 20px calc(var(--safe-bottom) + 24px);
      transform: translateY(100%);
      transition: transform .35s cubic-bezier(.32,1.25,.65,1);
    }
    #checkout-modal.open .modal-sheet { transform: translateY(0); }
    .modal-handle {
      width: 36px; height: 4px; background: #2d3f61;
      border-radius: 2px; margin: 0 auto 20px;
    }
    .modal-title {
      font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.1rem; margin-bottom: 16px;
    }
    .modal-line {
      display: flex; align-items: center; justify-content: space-between;
      padding: 10px 0; border-bottom: 1px solid rgba(255,255,255,0.05);
      font-size: 0.85rem;
    }
    .modal-line:last-of-type { border-bottom: none; }
    .modal-line .lbl { color: #8899bb; }
    .modal-line .val { font-weight: 700; font-family: 'Syne', sans-serif; }
    .modal-line .val.total { color: #00d4aa; font-size: 1.15rem; }
    .pay-methods { display: flex; gap: 8px; margin: 14px 0; }
    .pay-method {
      flex: 1; padding: 12px 8px; border-radius: 12px; text-align: center;
      border: 2px solid rgba(255,255,255,0.08); cursor: pointer;
      font-size: 0.78rem; font-weight: 700; color: #8899bb;
      background: #1a2235; transition: all .2s;
    }
    .pay-method.selected { border-color: #00d4aa; color: #00d4aa; background: rgba(0,212,170,0.08); }
    .pay-method .pay-icon { font-size: 1.3rem; margin-bottom: 4px; }
    .confirm-btn {
      width: 100%; padding: 14px;
      background: linear-gradient(135deg, #00d4aa, #00a885);
      color: #0a0f1e; border: none; border-radius: 14px;
      font-family: 'Syne', sans-serif; font-weight: 800; font-size: 0.95rem;
      cursor: pointer; margin-top: 12px;
      box-shadow: 0 4px 20px rgba(0,212,170,0.3);
      transition: transform .15s, box-shadow .15s;
    }
    .confirm-btn:active { transform: scale(0.97); }

    /* RTL adjustments */
    [dir="rtl"] .item-price { text-align: start; }
    [dir="rtl"] .logo { background: linear-gradient(225deg, #00d4aa 30%, #7fffd4);
                         -webkit-background-clip: text; -webkit-text-fill-color: transparent; }

    /* Numeric always LTR */
    .num-ltr { direction: ltr; unicode-bidi: embed; }
  </style>
</head>

<body>
<div id="app">

  <!-- ══ HTTPS WARNING (hidden on secure origins) ══ -->
  <div id="https-warning" style="display:none;flex-shrink:0;background:#ff6b6b;color:#0a0f1e;font-family:'Syne',sans-serif;font-weight:700;font-size:0.72rem;text-align:center;padding:8px 16px;line-height:1.5;z-index:100;">
    ⚠️ Camera requires HTTPS. Open this page via GitHub Pages or another HTTPS URL — not a local file or http:// link.
  </div>

  <!-- ══ TOPBAR ══ -->
  <header id="topbar">
    <div class="logo" id="app-logo">PharmaPOS</div>
    <div style="display:flex;align-items:center;gap:10px;">
      <div id="hub-badge" style="font-size:.65rem;font-weight:700;color:#8899bb;background:#1a2235;padding:3px 10px;border-radius:10px;" class="num-ltr">Baghdad Hub</div>
      <div class="lang-pill">
        <button class="lang-btn active" onclick="setLang('en')" id="btn-en">EN</button>
        <button class="lang-btn"        onclick="setLang('ar')" id="btn-ar">ع</button>
      </div>
    </div>
  </header>

  <!-- ══ SCREENS ══ -->
  <div id="screen-wrap">

    <!-- POS Screen -->
    <div class="screen active" id="pos-screen">

      <!-- Scanner Section -->
      <div id="scanner-section">
        <div id="scanner-card" class="idle">
          <!-- Tap-to-scan placeholder -->
          <div id="tap-placeholder" onclick="startScanner()">
            <div class="scan-icon-ring">
              <svg viewBox="0 0 24 24" fill="none" stroke="#00d4aa" stroke-width="2" stroke-linecap="round" width="32" height="32">
                <path d="M3 7V5a2 2 0 0 1 2-2h2M17 3h2a2 2 0 0 1 2 2v2M21 17v2a2 2 0 0 1-2 2h-2M7 21H5a2 2 0 0 1-2-2v-2"/>
                <rect x="7" y="7" width="3" height="3" rx="1" fill="#00d4aa" stroke="none"/>
                <rect x="14" y="7" width="3" height="3" rx="1" fill="#00d4aa" stroke="none"/>
                <rect x="7" y="14" width="3" height="3" rx="1" fill="#00d4aa" stroke="none"/>
                <rect x="14" y="14" width="3" height="3" rx="1" fill="#2d3f61" stroke="none"/>
              </svg>
            </div>
            <div>
              <div style="font-family:'Syne',sans-serif;font-weight:800;font-size:.95rem;text-align:center;" id="tap-label">Tap to Scan</div>
              <div style="font-size:.7rem;color:#8899bb;text-align:center;margin-top:2px;" id="tap-sub">Point camera at barcode or QR</div>
            </div>
          </div>

          <!-- html5-qrcode mounts here -->
          <div id="reader" class="hidden"></div>

          <!-- Corner overlay + scan line (shown when active) -->
          <div class="scan-overlay" id="scan-overlay" style="display:none;">
            <div class="corner tl"></div>
            <div class="corner tr"></div>
            <div class="corner bl"></div>
            <div class="corner br"></div>
            <div class="scan-line"></div>
          </div>
        </div>

        <!-- Label bar below scanner -->
        <div class="scanner-label">
          <div class="scan-badge" id="scanner-status-badge">READY</div>
          <button id="stop-scan-btn" onclick="stopScanner()" style="display:none;font-size:.7rem;font-weight:700;color:#ff6b6b;background:rgba(255,107,107,.1);border:none;padding:4px 12px;border-radius:10px;cursor:pointer;">■ Stop</button>
          <div class="scan-count-badge num-ltr" id="scan-count-badge">0 items scanned</div>
        </div>
      </div>

      <!-- Cart Section -->
      <div id="cart-section">
        <div class="cart-header">
          <div class="cart-title" id="cart-title-label">Invoice</div>
          <button class="clear-btn" onclick="clearCart()" id="clear-btn">Clear All</button>
        </div>

        <div id="empty-cart">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
