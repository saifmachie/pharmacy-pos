/* ── Scanner ── */
let _videoObserver = null;

function patchVideoForIOS(readerEl) {
  if (_videoObserver) { _videoObserver.disconnect(); _videoObserver = null; }

  function applyAttrs(video) {
    video.setAttribute('playsinline', '');
    video.setAttribute('webkit-playsinline', '');
    video.setAttribute('muted', '');
    video.setAttribute('autoplay', '');
    video.muted = true;
    video.style.maxHeight = '240px';
    video.style.width = '100%';
    video.style.objectFit = 'cover';
  }

  readerEl.querySelectorAll('video').forEach(applyAttrs);

  _videoObserver = new MutationObserver(mutations => {
    for (const m of mutations) {
      m.addedNodes.forEach(node => {
        if (node.nodeName === 'VIDEO') applyAttrs(node);
        if (node.querySelectorAll) node.querySelectorAll('video').forEach(applyAttrs);
      });
    }
  });
  _videoObserver.observe(readerEl, { childList: true, subtree: true });
}

function startScanner() {
  if (location.protocol !== 'https:' && location.hostname !== 'localhost' && location.hostname !== '127.0.0.1') {
    showToast('⚠️ HTTPS required for camera', 'error');
    return;
  }

  document.getElementById('tap-placeholder').classList.add('hidden');
  document.getElementById('reader').classList.remove('hidden');
  document.getElementById('scan-overlay').style.display = 'block';
  document.getElementById('stop-scan-btn').style.display = 'block';
  document.getElementById('scanner-status-badge').textContent = t('scannerActive');
  scanning = true;

  const readerEl = document.getElementById('reader');
  patchVideoForIOS(readerEl);

  scanner = new Html5Qrcode('reader', {
    verbose: false,
    experimentalFeatures: { useBarCodeDetectorIfSupported: true },
  });

  const config = {
    fps: 10,
    qrbox: { width: Math.min(window.innerWidth - 80, 220), height: 160 },
    aspectRatio: 1.5,
    supportedScanTypes: [Html5QrcodeScanType.SCAN_TYPE_CAMERA],
    videoConstraints: {
      facingMode: { ideal: 'environment' },
      width:  { ideal: 1280 },
      height: { ideal: 720 },
    },
  };

  scanner.start(
    { facingMode: { ideal: 'environment' } },
    config,
    onScanSuccess,
    () => {}
  ).catch(err => {
    console.error('Scanner start error:', err);
    const msg = String(err);
    if (/permission|denied/i.test(msg)) {
      showToast('Camera permission denied', 'error');
    } else if (/https|secure/i.test(msg)) {
      showToast('⚠️ HTTPS required for camera', 'error');
    } else {
      showToast('Camera unavailable', 'error');
    }
    stopScanner();
  });
}

function stopScanner() {
  if (_videoObserver) { _videoObserver.disconnect(); _videoObserver = null; }
  if (scanner && scanning) {
    scanner.stop().catch(() => {}).finally(() => {
      scanner = null;
      scanning = false;
      document.getElementById('tap-placeholder').classList.remove('hidden');
      document.getElementById('reader').classList.add('hidden');
      document.getElementById('scan-overlay').style.display = 'none';
      document.getElementById('stop-scan-btn').style.display = 'none';
      document.getElementById('scanner-status-badge').textContent = t('scannerReady');
    });
  }
}

function onScanSuccess(decodedText) {
  if (onScanSuccess._lastCode === decodedText && Date.now() - onScanSuccess._lastTime < 1500) return;
  onScanSuccess._lastCode = decodedText;
  onScanSuccess._lastTime = Date.now();
  if (navigator.vibrate) navigator.vibrate(60);
  addToCart(decodedText);
}
onScanSuccess._lastCode = null;
onScanSuccess._lastTime = 0;

/* ── Cart Logic ── */
function addToCart(barcode) {
  const product = PRODUCTS[barcode];
  if (!product) { showToast(t('toastNotFound'), 'error'); return; }
  const existing = cart.find(i => i.product.id === product.id);
  if (existing) {
    existing.qty++;
    showToast(t('toastExists', lang === 'ar' ? product.nameAr : product.name), 'success');
  } else {
    cart.push({ product, qty: 1 });
    showToast(t('toastScanned', lang === 'ar' ? product.nameAr : product.name), 'success');
  }
  renderCart();
  updateScanCountBadge();
}

function removeFromCart(id) {
  cart = cart.filter(i => i.product.id !== id);
  renderCart();
  updateScanCountBadge();
}

function changeQty(id, delta) {
  const item = cart.find(i => i.product.id === id);
  if (!item) return;
  item.qty += delta;
  if (item.qty <= 0) { removeFromCart(id); return; }
  renderCart();
}

function clearCart() {
  cart = [];
  renderCart();
  updateScanCountBadge();
}

function getTotal() {
  return cart.reduce((sum, i) => sum + i.product.price * i.qty, 0);
}

function renderCart() {
  const container = document.getElementById('cart-items');
  const empty     = document.getElementById('empty-cart');
  const checkBtn  = document.getElementById('checkout-btn');
  const total     = getTotal();
  document.getElementById('total-display').textContent = total.toLocaleString();
  checkBtn.disabled = cart.length === 0;
  if (cart.length === 0) {
    empty.style.display = 'flex';
    container.innerHTML = '';
    return;
  }
  empty.style.display = 'none';
  container.innerHTML = cart.map(({ product, qty }) => {
    const name = lang === 'ar' ? product.nameAr : product.name;
    const lineTotal = (product.price * qty).toLocaleString();
    return `
    <div class="cart-item" id="ci-${product.id}">
      <div class="item-icon" style="background:${product.color};">${product.icon}</div>
      <div class="item-info">
        <div class="item-name">${name}</div>
        <div class="item-meta num-ltr">${product.price.toLocaleString()} IQD · ${product.category}</div>
      </div>
      <div class="item-controls">
        <button class="qty-btn qty-minus" onclick="changeQty('${product.id}',-1)">−</button>
        <span class="qty-val num-ltr">${qty}</span>
        <button class="qty-btn qty-plus"  onclick="changeQty('${product.id}',1)">+</button>
      </div>
      <div class="item-price num-ltr">${lineTotal}</div>
    </div>`;
  }).join('');
}

function updateScanCountBadge() {
  const total = cart.reduce((s, i) => s + i.qty, 0);
  document.getElementById('scan-count-badge').textContent = t('itemsScanned', total);
}

/* ── Checkout Modal ── */
function openCheckout() {
  if (cart.length === 0) return;
  const total = getTotal();
  const items = cart.reduce((s, i) => s + i.qty, 0);
  document.getElementById('modal-items-val').textContent = items;
  document.getElementById('modal-sub-val').textContent   = total.toLocaleString() + ' IQD';
  document.getElementById('modal-total-val').textContent = total.toLocaleString() + ' IQD';
  document.getElementById('checkout-modal').classList.add('open');
}

function closeCheckout() {
  document.getElementById('checkout-modal').classList.remove('open');
}

function closeCheckoutOutside(e) {
  if (e.target === document.getElementById('checkout-modal')) closeCheckout();
}

function selectPayment(method) {
  selectedPayment = method;
  ['cash','qi','transfer'].forEach(m => {
    document.getElementById('pay-' + m).classList.toggle('selected', m === method);
  });
}

function confirmSale() {
  closeCheckout();
  setTimeout(() => {
    showToast(t('toastSaleComplete'), 'success');
    clearCart();
  }, 300);
}

/* ── Toast ── */
let _toastTimer = null;
function showToast(msg, type = 'success') {
  const el = document.getElementById('toast');
  document.getElementById('toast-msg').textContent = msg;
  el.className = 'show ' + type;
  clearTimeout(_toastTimer);
  _toastTimer = setTimeout(() => { el.className = ''; }, 2200);
}

/* ── Dev helper: type simulateScan('111') in browser console ── */
window.simulateScan = (code) => onScanSuccess(code);

/* ── Init ── */
(function checkHTTPS() {
  const isSecure = location.protocol === 'https:' ||
                   location.hostname === 'localhost' ||
                   location.hostname === '127.0.0.1';
  if (!isSecure) document.getElementById('https-warning').style.display = 'block';
})();

applyTranslations();
renderCart();
</script>
</body>
</html>
